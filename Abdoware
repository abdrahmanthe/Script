---------------------------------------------------
-- MOVE SYSTEM
---------------------------------------------------

moveButton.MouseButton1Click:Connect(function()
	if moving then return end
	if not savedPosition then return end

	moving = true

	local character = player.Character or player.CharacterAdded:Wait()
	local humanoid = character:WaitForChild("Humanoid")
	local hrp = character:WaitForChild("HumanoidRootPart")

	local speed = currentSpeed
	local flyHeight = tonumber(heightBox.Text) or 25

	if tweenEnabled then

		local elevatedPosition = Vector3.new(
			savedPosition.X,
			savedPosition.Y + flyHeight,
			savedPosition.Z
		)

		local distance = (hrp.Position - elevatedPosition).Magnitude
		local tweenTime = distance / speed

		local tween = TweenService:Create(
			hrp,
			TweenInfo.new(tweenTime, Enum.EasingStyle.Linear),
			{
				CFrame = CFrame.new(elevatedPosition)
			}
		)

		tween:Play()
		tween.Completed:Wait()

		local finalDistance = (hrp.Position - savedPosition).Magnitude
		local finalTweenTime = finalDistance / speed

		local finalTween = TweenService:Create(
			hrp,
			TweenInfo.new(finalTweenTime, Enum.EasingStyle.Linear),
			{
				CFrame = CFrame.new(savedPosition)
			}
		)

		finalTween:Play()
		finalTween.Completed:Wait()

	else

		humanoid.WalkSpeed = speed

		local path = PathfindingService:CreatePath({
			AgentRadius = 2,
			AgentHeight = 5,
			AgentCanJump = true,
			AgentJumpHeight = 7,
			AgentMaxSlope = 45
		})

		path:ComputeAsync(hrp.Position, savedPosition)

		if path.Status == Enum.PathStatus.Success then
			for _, waypoint in ipairs(path:GetWaypoints()) do

				if waypoint.Action == Enum.PathWaypointAction.Jump then
					humanoid.Jump = true
				end

				humanoid:MoveTo(waypoint.Position)

				local reached = humanoid.MoveToFinished:Wait()

				if not reached then
					break
				end
			end
		end

		humanoid.WalkSpeed = 16
	end

	moving = false
end)

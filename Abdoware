---------------------------------------------------
-- SPEED SLIDER
---------------------------------------------------

local currentSpeed = 60
local minSpeed = 10
local maxSpeed = 200

local speedLabel = Instance.new("TextLabel")
speedLabel.Size = UDim2.new(0.8,0,0,25)
speedLabel.Position = UDim2.new(0.1,0,0.15,0)
speedLabel.BackgroundTransparency = 1
speedLabel.Text = "Tween Speed: "..currentSpeed
speedLabel.TextScaled = true
speedLabel.TextColor3 = Color3.new(1,1,1)
speedLabel.Parent = frame

local sliderBack = Instance.new("Frame")
sliderBack.Size = UDim2.new(0.8,0,0,12)
sliderBack.Position = UDim2.new(0.1,0,0.25,0)
sliderBack.BackgroundColor3 = Color3.fromRGB(60,60,60)
sliderBack.Parent = frame

Instance.new("UICorner", sliderBack)

local sliderFill = Instance.new("Frame")
sliderFill.Size = UDim2.new(0.25,0,1,0)
sliderFill.BackgroundColor3 = Color3.fromRGB(70,170,255)
sliderFill.Parent = sliderBack

Instance.new("UICorner", sliderFill)

local sliderButton = Instance.new("TextButton")
sliderButton.Size = UDim2.new(0,18,0,18)
sliderButton.Position = UDim2.new(0.25,-9,0.5,-9)
sliderButton.Text = ""
sliderButton.BackgroundColor3 = Color3.new(1,1,1)
sliderButton.Parent = sliderBack

Instance.new("UICorner", sliderButton)

local dragging = false

local function updateSlider(input)
	local sizeX = math.clamp(
		(input.Position.X - sliderBack.AbsolutePosition.X)
		/ sliderBack.AbsoluteSize.X,
		0,
		1
	)

	sliderFill.Size = UDim2.new(sizeX,0,1,0)
	sliderButton.Position = UDim2.new(sizeX,-9,0.5,-9)

	currentSpeed = math.floor(minSpeed + ((maxSpeed - minSpeed) * sizeX))

	speedLabel.Text = "Tween Speed: "..currentSpeed
end

sliderButton.MouseButton1Down:Connect(function()
	dragging = true
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		updateSlider(input)
	end
end)

